{
  "name": "grok-video-web",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted Grok image-to-video studio.",
  "type": "module",
  "scripts": {
    "dev": "node --no-warnings=ExperimentalWarning --import tsx src/server/server.ts",
    "build": "vp build && npm run build:server",
    "build:client": "vp build",
    "build:server": "tsc -p tsconfig.server.json",
    "check": "vp check && tsc --noEmit -p tsconfig.server.json",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix",
    "login": "node --no-warnings=ExperimentalWarning --import tsx src/server/login.ts",
    "login:grok": "node --no-warnings=ExperimentalWarning --import tsx src/server/login.ts",
    "launch": "npm run build && node dist/server/server/launch.js",
    "smoke": "node scripts/smoke.mjs",
    "test": "vp test",
    "start": "node dist/server/server/launch.js"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "multer": "^2.0.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "playwright": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "packageManager": "npm@11.16.0"
}
