HOST=127.0.0.1
PORT=8787
ACCESS_TOKEN=
WORKSPACE_DIR=~/.grok-studio/workspace

XAI_AUTH_MODE=oauth
XAI_API_KEY=
XAI_OAUTH_TOKEN=
XAI_OAUTH_TOKEN_FILE=~/.grok-video-web/xai-oauth.json
XAI_BASE_URL=https://api.x.ai/v1
XAI_VIDEO_MODEL=grok-imagine-video
XAI_IMAGE_MODEL=grok-imagine-image-quality

DEFAULT_DURATION_SECONDS=6
DEFAULT_RESOLUTION=720p
DEFAULT_ASPECT_RATIO=source
POLL_INTERVAL_SECONDS=8
POLL_TIMEOUT_SECONDS=1200
MAX_VARIATIONS=3
