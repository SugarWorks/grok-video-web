{
  "name": "grok-studio",
  "version": "0.1.3",
  "private": false,
  "description": "Self-hosted Grok image-to-video studio (web app + CLI).",
  "bin": {
    "grok-studio": "dist/server/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vp exec tsx src/server/cli.ts serve",
    "build": "vp build && vp build --ssr src/server/cli.ts --outDir dist/server",
    "build:client": "vp build",
    "build:server": "vp build --ssr src/server/cli.ts --outDir dist/server",
    "check": "vp fmt --check && vp lint --deny-warnings && vp check --no-fmt --no-lint",
    "fmt": "vp fmt",
    "fmt:check": "vp fmt --check",
    "lint": "vp lint --deny-warnings",
    "lint:fix": "vp lint --fix",
    "typecheck": "vp check --no-fmt --no-lint",
    "login": "vp exec tsx src/server/cli.ts login",
    "login:grok": "vp exec tsx src/server/cli.ts login",
    "launch": "vp run build && vp run start",
    "smoke": "node scripts/smoke.mjs",
    "test": "vp test",
    "start": "node dist/server/cli.js serve",
    "cli": "vp exec tsx src/server/cli.ts",
    "prepack": "vp run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "@xyflow/react": "^12.11.0",
    "commander": "^15.0.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "multer": "^2.0.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "yet-another-react-lightbox": "^3.32.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-oxc": "^0.4.3",
    "playwright": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "engines": {
    "node": ">=22.5.0"
  },
  "packageManager": "npm@11.16.0"
}
